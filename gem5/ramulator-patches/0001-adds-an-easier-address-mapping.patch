--- a/src/dram_controller/impl/rowpolicy/basic_rowpolicies.cpp
+++ b/src/dram_controller/impl/rowpolicy/basic_rowpolicies.cpp
@@ -51,7 +51,7 @@ class ClosedRowPolicy : public IRowPolicy, public Implementation {
       m_ctrl = cast_parent<IDRAMController>();
       m_dram = m_ctrl->m_dram;
 
-      m_cap = param<int>("cap").default_val(10000000); // TODO
+      m_cap = param<int>("cap").default_val(1); // TODO
 
       m_rank_level = m_dram->m_levels("rank");
       m_bankgroup_level = m_dram->m_levels("bankgroup");
@@ -108,12 +108,10 @@ class ClosedRowPolicy : public IRowPolicy, public Implementation {
         
         m_col_accesses[flat_bank_id]++;
 
-        if (m_col_accesses[flat_bank_id] >= m_cap) {
           Request req(req_it->addr_vec, m_PRE_req_id);
           m_ctrl->priority_send(req);
           m_col_accesses[flat_bank_id] = 0;
           s_num_close_reqs++;
-        }
       }
     };
 };
